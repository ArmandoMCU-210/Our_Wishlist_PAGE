# Copia este archivo como ".env" y rellena tus propios valores.
# Nunca subas el archivo ".env" real a git.

# MongoDB Atlas (o local): cadena de conexión completa
MONGO_URI=mongodb+srv://usuario:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGO_DB_NAME=our_wishlist

# Cloudinary (dashboard.cloudinary.com -> Dashboard -> API Keys)
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# Contraseña secreta para marcar/desmarcar regalos como entregados.
# Solo tú (Arman) debes conocerla.
DELIVER_PASSWORD=cambia-esto-por-una-contrasena-segura
